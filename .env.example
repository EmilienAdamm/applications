# Supabase — direct Postgres connection string
# Found in: Supabase Dashboard → Project Settings → Database → Connection string (URI / direct)
DATABASE_URL=

# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Exposed to the browser — same value as BETTER_AUTH_URL for local dev
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI to add: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
